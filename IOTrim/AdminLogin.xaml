<Window x:Class="Delta_Riveting.AdminLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Topmost="True"
        Title="Admin Login - Riveting Automation"
        Height="450"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#F9FAFB"
        FontFamily="Segoe UI">

    <Grid>

        <!-- Main Card -->
        <Border Margin="20"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  Opacity="0.1"
                                  ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,0,0,1"
                        Padding="20,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="delta_logo.png"
                               Height="32"
                               VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="ADMIN PORTAL"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="IO Trim"
                                       FontSize="10"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CONTENT -->
                <StackPanel Grid.Row="1"
                            Margin="35,18,35,10"
                            VerticalAlignment="Center">

                    <!-- WELCOME -->
                    <StackPanel Margin="0,0,0,18"
                                HorizontalAlignment="Center">
                        <TextBlock Text="WELCOME BACK"
                                   FontSize="20"
                                   FontWeight="ExtraBold"
                                   Foreground="#24A6F1"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Please enter your credentials to continue"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- USERNAME -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Username"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,5"/>
                        <Border Height="38"
                                CornerRadius="6"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Background="#FAFAFA">
                            <TextBox x:Name="txtUsername"
                                     Text="Admin"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="14,0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- PASSWORD -->
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Password"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,5"/>
                        <Border Height="38"
                                CornerRadius="6"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Background="#FAFAFA">
                            <PasswordBox x:Name="txtPassword"
                                         Password="admin123"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="14,0"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- BUTTONS -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,6,0,0">

                        <!-- LOGIN -->
                        <Button x:Name="btnLogin"
                                Content="LOGIN"
                                Width="140"
                                Height="42"
                                Click="Login_Click"
                                Background="#24A6F1"
                                Foreground="White"
                                FontSize="14"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#007ACC"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#0066B3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- CLOSE -->
                        <Button Content="CLOSE"
                                Width="100"
                                Height="42"
                                Click="Close_Click"
                                Background="red"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#D1D5DB"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#9CA3AF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </StackPanel>

                <!-- FOOTER -->
                <Border Grid.Row="2"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,1,0,0"
                        Padding="15">
                    <TextBlock Text="© 2026 DELTA ELECTRONICS - PRODUCTION INTERFACE"
                               FontSize="10"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"/>
                </Border>

            </Grid>
        </Border>

        <!-- PROCESSING OVERLAY -->
        <Border x:Name="ProcessingOverlay"
                Background="#CC111827"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Border Background="#1F2937"
                        CornerRadius="12"
                        Padding="30,20">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#24A6F1"
                                 Margin="0,0,15,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1"
                                                             To="0.3"
                                                             Duration="0:0:0.8"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="VERIFYING CREDENTIALS..."
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

    </Grid>
</Window>
