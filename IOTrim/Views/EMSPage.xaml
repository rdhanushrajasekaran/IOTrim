<Page x:Class="IOTrim.Views.EMSPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid >

        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--========================================================
            TOP NAVIGATION
        =========================================================-->
        <Border Grid.Row="0"
                Width="320"
                Height="50"
                Background="{DynamicResource AppSurfaceBrush}"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">

            <Border.Effect>
                <DropShadowEffect BlurRadius="12"
                                  ShadowDepth="2"
                                  Opacity="0.18"/>
            </Border.Effect>

            <UniformGrid Columns="2" Margin="4">

                <!-- EMS -->
                <Button Tag="Dashboard"
                        Click="EMSNavBtnClicked"
                        Style="{StaticResource NavBarBtnStyle}">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="30"
                                Height="30"
                                CornerRadius="9"
                                Background="{DynamicResource AppIconInfoBrush}"
                                Margin="0,0,4,0">

                            <Image Source="/Resources/Icons/ico_dashboard.png" Height="20"/>

                        </Border>

                        <TextBlock Text="Dashboard"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Button>

                <!-- Hourly -->
                <Button Tag="HourlyData"
                        Click="EMSNavBtnClicked"
                        Style="{StaticResource NavBarBtnStyle}">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="30"
                                Height="30"
                                CornerRadius="9"
                                Background="{DynamicResource AppIconSuccessBrush}"
                                Margin="0,0,4,0">

                            <Image Source="/Resources/Icons/ico_hourly.png" Height="20"/>

                        </Border>

                        <TextBlock Text="Hourly"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Button>


            </UniformGrid>

        </Border>

        <!--========================================================
            CONTENT
        =========================================================-->

        <Border Grid.Row="1"
                Background="Transparent" Margin="4">

            <Frame x:Name="EMSFrm"
                   Background="Transparent"
                   NavigationUIVisibility="Hidden"/>

        </Border>

    </Grid>

</Page>