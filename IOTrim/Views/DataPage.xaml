<Page x:Class="IOTrim.Views.DataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:wpftoolkit="clr-namespace:IOTrim.CustomControls"
      xmlns:local="clr-namespace:IOTrim.Views"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="1000"
      Title="DataPage">

    

    <Grid Background="Transparent">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search Area -->
        <Border Grid.Row="0"
                Margin="10"
                Padding="10"
                Background="Transparent"
                CornerRadius="10">

            <WrapPanel>

                <!-- Date Filter -->
                <GroupBox Header="Date Filter"
                          Style="{StaticResource CardGroupBoxStyle}">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Label Content="From :"
                                   Width="60"
                                   Style="{StaticResource FormLabelStyle}"/>

                            <wpftoolkit:ModernDateTimePicker x:Name="FromDatePicker"
                           ShowTime="True"
                           PickerWidth="340"
                           PopupWidth="560"
                           InputHeight="40"
                           InputWidth="250"
                           InputCornerRadius="5"
                           InputBackground="{DynamicResource AppSurfaceStrongBrush}"
                           InputBorderBrush="{DynamicResource AppBorderBrush}"
                           InputBorderThickness="1"
                           InputTextBrush="{DynamicResource AppTextBrush}"
                           Theme="Light"
                           DisableFutureDates="True" Width="263"/>
                            
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Label Content="To :"
                                   Width="60"
                                   Style="{StaticResource FormLabelStyle}"/>

                            <wpftoolkit:ModernDateTimePicker x:Name="ToDatePicker"
                                                             ShowTime="True"
                                PickerWidth="340"
                                PopupWidth="560"
                                InputHeight="40"
                                InputWidth="250"
                                InputCornerRadius="5"
                                InputBackground="{DynamicResource AppSurfaceBrush}"
                                InputBorderBrush="{DynamicResource AppBorderBrush}"
                                InputBorderThickness="1"
                                InputTextBrush="{DynamicResource AppTextBrush}"
                                Theme="Light"
                                DisableFutureDates="True" Width="261"/>

                            <Button x:Name="DateSearchBtn" Content="Search" Style="{StaticResource SearchBtnStyle}" Click="DateSearchBtn_Click"/>
                            <Button x:Name="DateSearchExport" Content="Export" Background="{DynamicResource AppExportBrush}" Style="{StaticResource SearchBtnStyle}" Click="Export_Click"/>
                        </StackPanel>

                        
                    </StackPanel>

                </GroupBox>

                <!-- Serial Search -->
                <GroupBox Header="Serial Number Filter"
                          Style="{StaticResource CardGroupBoxStyle}">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Label Content="Holder Serial :"
                                   Width="98"
                                   Style="{StaticResource FormLabelStyle}"/>

                            <TextBox x:Name="HolderSerialTxtBox"
                                     Style="{StaticResource FormTextBoxStyle}"/>

                            <Button x:Name="HolderSerialSearchBtn" Content="Search" Style="{StaticResource SearchBtnStyle}" Click="HolderSerialSearchBtn_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Label Content="BL Serial :"
                                   Width="97"
                                   Style="{StaticResource FormLabelStyle}"/>

                            <TextBox x:Name="blSerialNoTxtBox"
                                     Style="{StaticResource FormTextBoxStyle}"/>

                            <Button x:Name="blSerailSearchBtn" Content="Search" Style="{StaticResource SearchBtnStyle}" Click="blSerailSearchBtn_Click"/>
                            <Button x:Name="SerailSearchExport" Content="Export" Background="{DynamicResource AppExportBrush}" Style="{StaticResource SearchBtnStyle}" Click="Export_Click"/>
                        </StackPanel>

                    </StackPanel>

                </GroupBox>

                <!-- Sort -->
                <GroupBox Header="Filter"
                          Style="{StaticResource CardGroupBoxStyle}">

                    <StackPanel>

                        <ComboBox x:Name="cbSorting" Style="{StaticResource FormComboBoxStyle}" SelectionChanged="Soring_Changed">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="PVD"/>
                            <ComboBoxItem Content="Non PVD"/>
                            <ComboBoxItem Content="OK"/>
                            <ComboBoxItem Content="NOK"/>
                        </ComboBox>

                    </StackPanel>

                </GroupBox>

            </WrapPanel>

        </Border>

        <Border Grid.Row="1"
        Margin="10"
        Background="{DynamicResource AppSurfaceBrush}"
        CornerRadius="10">

            <DataGrid x:Name="dgproductionLog"
          AutoGenerateColumns="False"
          IsReadOnly="True"
                      Background="{DynamicResource AppSurfaceBrush}"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          RowHeaderWidth="0"
          ColumnHeaderStyle="{StaticResource  ModernDataGridColumnHeaderStyle}"
          CellStyle="{StaticResource  ModernDataGridCellStyle}"
          RowStyle="{StaticResource ModernDataGridRowStyle}"
                      VerticalScrollBarVisibility="Hidden"
          SelectionUnit="FullRow"
          ColumnWidth="SizeToHeader">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                            Binding="{Binding ID}" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Width="40"/>

                    <DataGridTextColumn Header="Date Time" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding DateTime}"
                            Width="170"/>

                    <DataGridTextColumn Header="BL Serial No" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding BLSerialNo}"
                            Width="120"/>

                    <DataGridTextColumn Header="Holder Serial No" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding HolderSerialNo}"
                            Width="120"/>

                    <DataGridTextColumn Header="Fixture No" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding FixtureNumber}"
                            Width="90"/>

                    <DataGridTextColumn Header="Station Name" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding StationName}"
                            Width="100"/>

                    <DataGridTextColumn Header="Shift" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding Shift}"
                            Width="50"/>

                    <DataGridTextColumn Header="Torque (Nm)" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding ScrewingTorque}"
                            Width="90"/>

                    <DataGridTextColumn Header="Angle" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding ScrewingAngle}"
                            Width="80"/>

                    <DataGridCheckBoxColumn Header="Screw OK" Width="70" IsReadOnly="True"
                        Binding="{Binding [ScrewingResult]}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox"
               BasedOn="{StaticResource CenteredCheckBoxStyle}"/>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridTextColumn Header="Press Load" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding BLPressingLoad}"
                            Width="90"/>

                    <DataGridCheckBoxColumn Header="Profilometer Result" Width="130" IsReadOnly="True"
                        Binding="{Binding [VisionInspection]}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox"
               BasedOn="{StaticResource CenteredCheckBoxStyle}"/>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridTextColumn Header="Profilometer Height" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding ProfiloMeterHeight,StringFormat=F2}"
                            Width="130"/>

                    <DataGridTextColumn Header="Variant" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding Variant}"
                            Width="100"/>

                    <DataGridTextColumn Header="Color" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding Color}"
                            Width="80"/>

                    <DataGridTextColumn Header="Count" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding Count}"
                            Width="70"/>

                    <DataGridTextColumn Header="Result" ElementStyle="{StaticResource CenteredTextBlockStyle}"
                            Binding="{Binding Result}"
                            Width="80"/>

                </DataGrid.Columns>

            </DataGrid>
        </Border>

    </Grid>

</Page>