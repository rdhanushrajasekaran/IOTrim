<Page x:Class="IOTrim.Views.OeeDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:chart="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="Transparent">

    <Grid Margin="14">

        <Grid.RowDefinitions>
            <RowDefinition Height="1.7*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- OEE Gauge -->
        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.RowSpan="2"
                Margin="0,0,8,0"
                CornerRadius="24"
                Padding="18"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border CornerRadius="16"
                        Padding="12"
                        Background="{DynamicResource AppBlueCardBrush}">

                    <StackPanel>
                        <TextBlock Text="Overall Equipment Effectiveness"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"/>

                        <TextBlock Text="Today's calculated OEE"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppBlueTextBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,10">

                    <chart:PieChart Width="290"
                Height="360"
                Series="{Binding GaugeSeries}"
                Background="Transparent"
                InitialRotation="-90"
                MaxAngle="360"
                MinValue="0"
                MaxValue="100"
                LegendPosition="Hidden"/>

                    <Border Width="185"
                            Height="185"
                            CornerRadius="95"
                            Background="{DynamicResource AppGaugeInnerBrush}"
                            BorderBrush="{DynamicResource AppAccentBrush}"
                            BorderThickness="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <TextBlock Text="{Binding OEEValueText}"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="OEE"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        CornerRadius="16"
                        Padding="14,10"
                        Background="{DynamicResource AppDataGridAltRowBrush}">

                    <Grid>
                        <TextBlock Text="OEE Percentage"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding OEEPercentText}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Time Details -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="8,0,8,8"
                CornerRadius="24"
                Padding="18"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border CornerRadius="16"
                        Padding="12"
                        Background="{DynamicResource AppDataGridAltRowBrush}">

                    <Grid>
                        <TextBlock Text="Time Details"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppTextBrush}"/>


                        <Grid Width="180" HorizontalAlignment="Right"
      Height="36">

                            <!-- Background -->
                            <Border Background="#EEF2F7"
            CornerRadius="18"/>

                            <!-- Sliding Indicator -->
                            <Border x:Name="SelectionIndicator"
            Width="60"
            Margin="2"
            HorizontalAlignment="Left"
            CornerRadius="16"
            Background="#2563EB"
            RenderTransformOrigin="0.5,0.5">

                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndicatorTransform"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border HorizontalAlignment="Right"
        VerticalAlignment="Center"
        CornerRadius="18"
        Padding="0"
        Background="Transparent">

                                <Grid Width="180" Height="36">

                                    <Border Background="#EEF2F7"
                CornerRadius="8"/>

                                    <Border x:Name="TimeUnitIndicator"
                Width="58"
                Height="30"
                Margin="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                CornerRadius="8"
                Background="#2563EB">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="TimeUnitIndicatorTransform" X="60"/>
                                        </Border.RenderTransform>
                                    </Border>

                                    <UniformGrid Columns="3">

                                        <Button x:Name="BtnSec"
                                                Style="{StaticResource FlatButtonStyle}"
                    Content="sec"
                    Tag="0"
                    Click="TimeUnit_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#111827"
                    FontSize="13"
                    FontWeight="SemiBold"/>

                                        <Button x:Name="BtnMin"
                                                Style="{StaticResource FlatButtonStyle}"
                    Content="min"
                    Tag="1"
                    Click="TimeUnit_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="13"
                    FontWeight="SemiBold"/>

                                        <Button x:Name="BtnHour"
                    Content="hour"
                    Tag="2"
                                                Style="{StaticResource FlatButtonStyle}"
                    Click="TimeUnit_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#111827"
                    FontSize="13"
                    FontWeight="SemiBold"/>

                                    </UniformGrid>

                                </Grid>
                            </Border>

                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="0,14,0,10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="Total Time" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalTime}" Style="{StaticResource TimeValueStyle}"/>

                    <TextBlock Grid.Row="1" Text="Total Available Time" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalAvailableTime}" Style="{StaticResource TimeValueStyle}"/>

                    <TextBlock Grid.Row="2" Text="Shift Break" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ShiftBreakTime}" Style="{StaticResource TimeValueStyle}"/>

                    <TextBlock Grid.Row="3" Text="Actual Running Time" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActualRunningTime}" Style="{StaticResource TimeValueStyle}"/>

                    <TextBlock Grid.Row="4" Text="Management Loss" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ManagementLossTime}" Style="{StaticResource TimeValueStyle}"/>

                    <TextBlock Grid.Row="5" Text="Planned Downtime" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PlannedDowntime}" Style="{StaticResource TimeValueStyle}"/>

                    <TextBlock Grid.Row="6" Text="Unplanned Down" Style="{StaticResource TimeLabelStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding UnplannedDowntime}" Style="{StaticResource TimeValueStyle}"/>
                </Grid>

                <Border Grid.Row="2"
                        Background="{DynamicResource AppBlueCardBrush}"
                        CornerRadius="18"
                        Padding="14,10">

                    <Grid>
                        <TextBlock Text="Idle Time"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppBlueTextBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding IdleTime}"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppBlueTextBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Parts Summary -->
        <Border Grid.Row="0"
                Grid.Column="2"
                Margin="8,0,0,8"
                CornerRadius="24"
                Padding="18"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border CornerRadius="16"
                        Padding="12"
                        Background="{DynamicResource AppDataGridAltRowBrush}">

                    <TextBlock Text="Parts Summary"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"/>
                </Border>

                <Grid Grid.Row="1"
                      Margin="0,14">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource AppGreenCardBrush}"
                            CornerRadius="18"
                            Padding="14"
                            Margin="0,0,0,7">

                        <Grid>
                            <TextBlock Text="Good Parts"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppGreenTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding GoodParts}"
                                       FontSize="27"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppGreenTextBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource AppOrangeCardBrush}"
                            CornerRadius="18"
                            Padding="14"
                            Margin="0,7,0,0">

                        <Grid>
                            <TextBlock Text="Bad Parts"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppOrangeTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding BadParts}"
                                       FontSize="27"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppOrangeTextBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="{DynamicResource AppAccentLightBrush}"
                        CornerRadius="20"
                        Padding="16">

                    <StackPanel>
                        <TextBlock Text="Total Parts"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding TotalParts}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- KPI Strip -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="8,8,0,0"
                CornerRadius="24"
                Padding="18"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Availability -->
                <Border Grid.Column="0"
                        Margin="0,0,8,0"
                        CornerRadius="18"
                        Padding="14"
                        Background="{DynamicResource AppGreenCardBrush}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Availability"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppGreenTextBrush}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding AvailabilityText}"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppGreenTextBrush}"
                                   VerticalAlignment="Center"/>

                        <ProgressBar Grid.Row="2"
                                     Height="8"
                                     Value="{Binding Availability}"
                                     Maximum="100"
                                     Foreground="{DynamicResource AppGreenTextBrush}"
                                     Style="{StaticResource ModernProgressBarStyle}"/>
                    </Grid>
                </Border>

                <!-- Performance -->
                <Border Grid.Column="1"
                        Margin="8,0"
                        CornerRadius="18"
                        Padding="14"
                        Background="{DynamicResource AppBlueCardBrush}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Performance"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppBlueTextBrush}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding PerformanceText}"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppBlueTextBrush}"
                                   VerticalAlignment="Center"/>

                        <ProgressBar Grid.Row="2"
                                     Height="8"
                                     Value="{Binding Performance}"
                                     Maximum="100"
                                     Foreground="{DynamicResource AppBlueTextBrush}"
                                     Style="{StaticResource ModernProgressBarStyle}"/>
                    </Grid>
                </Border>

                <!-- Quality -->
                <Border Grid.Column="2"
                        Margin="8,0,0,0"
                        CornerRadius="18"
                        Padding="14"
                        Background="{DynamicResource AppOrangeCardBrush}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Quality"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppOrangeTextBrush}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding QualityText}"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppOrangeTextBrush}"
                                   VerticalAlignment="Center"/>

                        <ProgressBar Grid.Row="2"
                                     Height="8"
                                     Value="{Binding Quality}"
                                     Maximum="100"
                                     Foreground="{DynamicResource AppOrangeTextBrush}"
                                     Style="{StaticResource ModernProgressBarStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Page>