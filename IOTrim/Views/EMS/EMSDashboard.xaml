<Page x:Class="IOTrim.Views.EMS.EMSDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:chart="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="Transparent"
      Title="EMSDashboard">

    <Page.Resources>
        <Storyboard x:Key="EmsIntro">
            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45"/>
            <DoubleAnimation Storyboard.TargetName="RootMove" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.55">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="FlowMove" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="FlowDotMove" Storyboard.TargetProperty="X" From="0" To="620" Duration="0:0:2.8"/>
            <DoubleAnimation Storyboard.TargetName="FlowDot" Storyboard.TargetProperty="Opacity" From="0.15" To="0.95" AutoReverse="True" Duration="0:0:1.4"/>
        </Storyboard>
        <Storyboard x:Key="WarningBreath" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="QualityRing" Storyboard.TargetProperty="Opacity" From="0.35" To="1" Duration="0:0:1.1"/>
        </Storyboard>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource EmsIntro}"/>
            <BeginStoryboard Storyboard="{StaticResource FlowMove}"/>
            <BeginStoryboard Storyboard="{StaticResource WarningBreath}"/>
        </EventTrigger>
    </Page.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="Root" Opacity="1" Margin="18,8,18,12">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="RootMove"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top energy busbar: different from card layout -->
            <Border Grid.Row="0" Background="{DynamicResource AppSurfaceStrongBrush}" CornerRadius="10" BorderBrush="{DynamicResource AppAccentBrush}" BorderThickness="0,0,0,4" Padding="10" Margin="8,0,8,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>


                    <StackPanel Grid.Column="0" Margin="10,0">
                        <TextBlock Text="APPARENT POWER" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="{Binding ApparentPowerText}" FontSize="27" FontWeight="Black" Foreground="{DynamicResource AppOrangeTextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0">
                        <TextBlock Text="ACTIVE POWER" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="{Binding ActivePowerText}" FontSize="27" FontWeight="Black" Foreground="{DynamicResource AppBlueTextBrush}"/>
                        <TextBlock Text="" Foreground="{DynamicResource AppMutedTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="10,0">
                        <TextBlock Text="REACTIVE POWER" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="{Binding ReactivePowerText}" FontSize="27" FontWeight="Black" Foreground="{DynamicResource AppTextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="10,0">
                        <TextBlock Text="TODAY ENERGY" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="{Binding TodayEnergyText}" FontSize="27" FontWeight="Black" Foreground="{DynamicResource AppGreenTextBrush}"/>
                        <TextBlock Text="A+B+C shift total" Foreground="{DynamicResource AppMutedTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main EMS layout: phase rails, flow chart, quality panel -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1.55*"/>
                    <ColumnDefinition Width="1.05*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelLineStyle}" CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="LIVE ELECTRICAL VALUES" Style="{StaticResource RailTitleStyle}" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="L1-L2" FontWeight="Bold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Value="{Binding L1L2VoltPercent}" Maximum="100" Style="{StaticResource ModernProgressBarStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding L1L2VoltText}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="L2-L3" FontWeight="Bold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Value="{Binding L2L3VoltPercent}" Maximum="100" Style="{StaticResource ModernProgressBarStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding L2L3VoltText}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="L3-L1" FontWeight="Bold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Value="{Binding L3L1VoltPercent}" Maximum="100" Style="{StaticResource ModernProgressBarStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding L3L1VoltText}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource AppBorderBrush}"/>

                        <Grid Margin="0,10,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Current L1" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding L1CurrentText}" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Text="Current L2" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding L2CurrentText}" FontWeight="Bold" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="2" Text="Current L3" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding L3CurrentText}" FontWeight="Bold" Margin="0,12,0,0"/>
                        </Grid>
                        
                        <Rectangle Height="1" Fill="{DynamicResource AppBorderBrush}" Margin="0"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Volt L1-N" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding L1VoltText}" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Text="Volt L2-N" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding L2VoltText}" FontWeight="Bold" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="2" Text="Volt L3-N" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding L3VoltText}" FontWeight="Bold" Margin="0,12,0,0"/>
                        </Grid>

                        <Border Background="{DynamicResource AppBlueCardBrush}" BorderBrush="{DynamicResource AppBlueTextBrush}" BorderThickness="4,0,0,0" Padding="10" Margin="0,18,0,0">
                            <Grid>
                                <TextBlock Text="Voltage Balance" FontWeight="SemiBold" Foreground="{DynamicResource AppBlueTextBrush}"/>
                                <TextBlock Text="{Binding VoltageBalanceStatus}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource AppBlueTextBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelLineStyle}" CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="260"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="LIVE POWER FLOW" Style="{StaticResource RailTitleStyle}"/>
                            <TextBlock Text="kW trend" HorizontalAlignment="Right" Foreground="{DynamicResource AppMutedTextBrush}"/>
                        </Grid>

                        <Grid Grid.Row="1" Height="44" Margin="0,12,0,8" ClipToBounds="True">
                            <Rectangle Height="5" Fill="{DynamicResource AppAccentBrush}" VerticalAlignment="Center" RadiusX="4" RadiusY="4"/>
                            <Ellipse x:Name="FlowDot" Width="16" Height="16" Fill="{DynamicResource AppGreenTextBrush}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="FlowDotMove"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <TextBlock Text="METER → PANEL → MACHINE" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="{DynamicResource AppMutedTextBrush}"/>
                        </Grid>

                        <chart:CartesianChart Grid.Row="2" Series="{Binding PowerSeries}" XAxes="{Binding PowerXAxes}" YAxes="{Binding PowerYAxes}" Background="Transparent" LegendPosition="Bottom"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelLineStyle}" CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="POWER QUALITY" Style="{StaticResource RailTitleStyle}"/>
                        <Grid Height="112" Margin="0,12,0,8">
                            <Ellipse x:Name="QualityRing" Stroke="{DynamicResource AppGreenTextBrush}" StrokeThickness="10" Opacity="0.55"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PowerFactorText}" FontSize="34" FontWeight="Black" HorizontalAlignment="Center"/>
                                <TextBlock Text="Power Factor" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Frequency" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FrequencyText}" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Text="Reactive Power" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ReactivePowerText}" FontWeight="Bold" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="2" Text="Apparent Power" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ApparentPowerText}" FontWeight="Bold" Margin="0,12,0,0"/>
                        </Grid>

                        <Border Background="{DynamicResource AppIconSuccessBrush}" BorderBrush="{DynamicResource AppGreenTextBrush}" BorderThickness="4,0,0,0" Padding="10" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="HIGH POWER WARNING" FontWeight="Bold" Foreground="{DynamicResource AppGreenTextBrush}"/>
                                <TextBlock Text="{Binding WarningText}" FontSize="22" FontWeight="Black" Foreground="{DynamicResource AppGreenTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom reports: timeline rows -->
            <Grid Grid.Row="2" Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource AppSurfaceBrush}" CornerRadius="10" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,1" Padding="10" Margin="0,6,8,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="SHIFT ENERGY" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="{Binding AShiftEnergyText}" FontWeight="SemiBold" Margin="0,16,0,0"/>
                        <ProgressBar Style="{StaticResource ModernProgressBarStyle}" Value="{Binding AShiftEnergyValue}" Maximum="100" Margin="0,6,0,12"/>
                        <TextBlock Text="{Binding BShiftEnergyText}" FontWeight="SemiBold"/>
                        <ProgressBar Style="{StaticResource ModernProgressBarStyle}" Value="{Binding BShiftEnergyValue}" Maximum="100" Margin="0,6,0,12"/>
                        <TextBlock Text="{Binding CShiftEnergyText}" FontWeight="SemiBold"/>
                        <ProgressBar Style="{StaticResource ModernProgressBarStyle}" Value="{Binding CShiftEnergyValue}" Maximum="100" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource AppSurfaceBrush}" CornerRadius="10" BorderBrush="{DynamicResource AppAccentBrush}" BorderThickness="0,0,0,4" Padding="18" Margin="0,6,8,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="MONTHLY ENERGY" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="{Binding MonthlyEnergyText}" FontSize="42" FontWeight="Black" Margin="0,12,0,0"/>
                        <TextBlock Text="Current month accumulated consumption" Foreground="{DynamicResource AppMutedTextBrush}"/>
                        <Grid Margin="0,18,0,0">
                            <TextBlock Text="Average / Day" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Text="{Binding AverageDayEnergyText}" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource AppSurfaceBrush}" CornerRadius="10" BorderBrush="{DynamicResource AppOrangeTextBrush}" BorderThickness="0,0,0,4" Padding="18" Margin="0,6,0,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="PANEL TEMPERATURE" Style="{StaticResource RailTitleStyle}"/>
                        <TextBlock Text="36.8 °C" FontSize="42" FontWeight="Black" Margin="0,12,0,0" Foreground="{DynamicResource AppOrangeTextBrush}"/>
                        <TextBlock Text="Panel / meter area temperature" Foreground="{DynamicResource AppMutedTextBrush}"/>
                        <Grid Margin="0,18,0,0">
                            <TextBlock Text="Thermal Status" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Text="Normal" HorizontalAlignment="Right" Foreground="{DynamicResource AppGreenTextBrush}" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
