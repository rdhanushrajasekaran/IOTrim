<UserControl x:Class="IOTrim.CustomControls.ModernDateTimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding PickerWidth, RelativeSource={RelativeSource Self}}">

    <UserControl.Resources>

        <Style x:Key="DayHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        </Style>

    </UserControl.Resources>

    <Grid>

        <Border x:Name="InputBorder"
                Height="{Binding InputHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Width="{Binding InputWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="{Binding InputCornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderBrush="{Binding InputBorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Background="{Binding InputBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Padding="14,0"
                BorderThickness="{Binding InputBorderThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Cursor="Hand"
                MouseLeftButtonDown="InputBorder_MouseLeftButtonDown">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtSelected"
                           Text="Select date"
                           FontSize="{Binding InputFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{Binding InputTextBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="📅"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="8,0"/>

                <Button Grid.Column="2"
                        Content="✕"
                        Width="28"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        Foreground="{DynamicResource AppMutedTextBrush}"
                        Click="Clear_Click"/>
            </Grid>
        </Border>

        <Popup x:Name="PickerPopup"
               PlacementTarget="{Binding ElementName=InputBorder}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade">

            <Border x:Name="PickerPanel"
                    Margin="0,8,0,0"
                    Width="{Binding PopupWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CornerRadius="28"
                    Padding="22"
                    BorderThickness="1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="3"
                                      Opacity="0.25"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="TimeColumn" Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="◀"
                                    Style="{StaticResource ArrowButtonStyle}"
                                    Click="PrevMonth_Click"/>

                            <TextBlock x:Name="txtMonth"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Grid.Column="1"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <Button Grid.Column="2"
                                    Content="▶"
                                    Style="{StaticResource ArrowButtonStyle}"
                                    Click="NextMonth_Click"/>
                        </Grid>

                        <UniformGrid Columns="7" Height="34">
                            <TextBlock Text="Su" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock Text="Mo" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock Text="Tu" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock Text="We" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock Text="Th" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock Text="Fr" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock Text="Sa" Style="{StaticResource DayHeaderStyle}"/>
                        </UniformGrid>

                        <UniformGrid x:Name="DaysGrid"
                                     Columns="7"
                                     Rows="6"/>
                    </StackPanel>

                    <StackPanel x:Name="TimeSection"
                                Grid.Column="1"
                                Margin="18,0,0,0">

                        <TextBlock Text="Time"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,18"/>

                        <ScrollViewer Height="270"
                                      VerticalScrollBarVisibility="Hidden">
                            <StackPanel x:Name="TimePanel"/>
                        </ScrollViewer>

                    </StackPanel>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</UserControl>