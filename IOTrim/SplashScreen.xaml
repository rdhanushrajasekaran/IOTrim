<Window x:Class="IOTrim.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/Icons/favicon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="600"
        Height="350">

    <Grid>

        <Border Background="White"
                CornerRadius="20"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid Margin="30">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Center -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <Image Source="/Resources/Icons/delta_logo.png"
                           Width="350"
                           Height="180"/>

                </StackPanel>

                <!-- Bottom -->
                <StackPanel Grid.Row="1"
                            Margin="20">

                    <TextBlock Text="Loading..."
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,0,0,8"/>

                    <Border Height="6"
                            CornerRadius="3"
                            Background="#E5E7EB"
                            ClipToBounds="True">

                        <Border Width="90"
                                Background="#2563EB"
                                HorizontalAlignment="Left"
                                CornerRadius="3">

                            <Border.RenderTransform>
                                <TranslateTransform X="-90"/>
                            </Border.RenderTransform>

                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                From="-90"
                                                To="760"
                                                Duration="0:0:1.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                        </Border>

                    </Border>

                    <TextBlock Text="Version 1.0"
                               HorizontalAlignment="Right"
                               Margin="0,12,0,0"
                               FontSize="12"
                               Foreground="#999999"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>